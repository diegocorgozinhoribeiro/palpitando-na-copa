# String de conexao do Neon (Postgres). NUNCA versione o .env real.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# Segredo para assinar as sessoes (gere um valor aleatorio longo).
# Ex.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="troque-por-um-valor-aleatorio-bem-grande"

# URL publica do app (usada para montar links de convite das ligas e de
# redefinicao de senha).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Envio de e-mail ("esqueci minha senha") por API HTTP.
# IMPORTANTE: o Render BLOQUEIA SMTP (Gmail da timeout la). Por isso usamos
# uma API HTTP. Configure UM dos provedores abaixo (todos tem plano gratis e
# funcionam sem dominio - basta verificar seu e-mail como remetente):
#
#   Brevo (recomendado, 300/dia): https://www.brevo.com
BREVO_API_KEY=""
#   SendGrid (100/dia): https://sendgrid.com
SENDGRID_API_KEY=""
#   Resend: https://resend.com
RESEND_API_KEY=""
#
# Remetente (precisa estar VERIFICADO no provedor escolhido; pode ser seu Gmail).
EMAIL_FROM="Palpitando na Copa <seuemail@gmail.com>"
