# String de conexao do Neon (Postgres). NUNCA versione o .env real.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# Segredo para assinar as sessoes (gere um valor aleatorio longo).
# Ex.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="troque-por-um-valor-aleatorio-bem-grande"

# URL publica do app (usada para montar links de convite das ligas e de
# redefinicao de senha).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Envio de e-mail para "esqueci minha senha" via Gmail (SMTP).
# Use uma "Senha de app" do Google (NAO a senha normal da conta):
#   1) Ative a verificacao em 2 etapas na Conta Google.
#   2) Gere uma Senha de app em https://myaccount.google.com/apppasswords
# Sem essas variaveis, o link de redefinicao apenas aparece no log (modo teste).
GMAIL_USER="seuemail@gmail.com"
GMAIL_APP_PASSWORD="as 16 letras da senha de app"
# (Opcional) Nome/remetente exibido. Por padrao usa o proprio GMAIL_USER.
EMAIL_FROM="Palpitando na Copa <seuemail@gmail.com>"
